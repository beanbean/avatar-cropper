{
  "name": "avatar-cropper",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/_worker.js/index.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
    "r2_buckets": [
    {
      "binding": "AVATARS",
      "bucket_name": "marathon-avatars"
    }
  ],
  "upload_source_maps": true
}
